# .gitignore for MySalesTracker (.NET, Blazor, EF Core)

# Build results
bin/
obj/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates
*.cursorrules
DeleteBinObjFolders.bat
TheSimplePlan.md
ThePlan.md
AI_Summary.md

# User-specific folders
Info/

# VS Code
.vscode/

# Rider
.idea/
*.sln.iml

# NuGet
*.nupkg
# NuGet Packages folder
packages/
# NuGet Symbol Packages
*.snupkg

# Entity Framework Migrations
# MySalesTracker.Data/Migrations/*Designer.cs
# MySalesTracker.Data/Migrations/*Snapshot.cs

# Logs
*.log

# OS generated files
.DS_Store
Thumbs.db

# Others
*.vspscc
*.vssscc

# Ignore secrets/configs (if any)
appsettings.*.local.json
appsettings.Production.json

# Ignore publish profiles (deployment-specific)
**/Properties/PublishProfiles/
 
# VS cache 
.vs/
